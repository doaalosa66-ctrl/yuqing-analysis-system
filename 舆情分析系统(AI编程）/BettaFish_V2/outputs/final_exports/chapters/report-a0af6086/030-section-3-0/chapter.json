                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "担忧噪音污染、安全风险、数据隐私和视觉侵扰。",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
