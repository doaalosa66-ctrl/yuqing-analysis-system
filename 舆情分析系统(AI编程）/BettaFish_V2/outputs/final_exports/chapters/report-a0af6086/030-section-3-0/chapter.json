                    {
                      "text": "科技爱好者/投资者",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "关注技术突破和产业龙头，视其为颠覆性投资机会。",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "积极、狂热",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            }
          ]
        },
        {
          "cells": [
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "普通市民/消费者",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "关心具体应用（物流、出行）是否方便、安全、便宜。",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "好奇、务实、略带怀疑",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            }
          ]
        },
        {
          "cells": [
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "政策研究者/学者",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "聚焦法规、标准、空域管理、社会公平等系统性议题。",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "理性、审慎、前瞻",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            }
          ]
        },
        {
          "cells": [
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "地方官员/从业者",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "视为发展机遇和就业来源，积极推动本地生态建设。",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            },
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "积极、急切",
                      "marks": []
                    }
                  ]
                }
              ],
              "align": "center"
            }
          ]
        },
        {
          "cells": [
            {
              "blocks": [
                {
                  "type": "paragraph",
                  "inlines": [
                    {
                      "text": "环保/隐私关切者",
